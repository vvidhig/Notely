# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Groq — get a free key at console.groq.com
GROQ_API_KEY=your-groq-api-key

# Notion OAuth — create an integration at notion.so/my-integrations
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=http://localhost:8000/api/notion/callback

# App
DATABASE_URL=sqlite:///./notely.db
CORS_ORIGINS=http://localhost:5173
AUTO_SUGGEST_THRESHOLD=3
